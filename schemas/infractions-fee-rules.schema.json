{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://uconn-law-library.github.io/CGS/schemas/infractions-fee-rules.schema.json",
  "title": "CGS infractions Chart B fee rules",
  "type": "object",
  "required": ["schemaVersion", "revision", "rules"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "revision": { "type": ["string", "null"] },
    "rules": {
      "type": "array",
      "items": { "$ref": "#/$defs/rule" }
    }
  },
  "$defs": {
    "resolution": {
      "type": "object",
      "required": ["status"],
      "additionalProperties": false,
      "properties": {
        "status": { "enum": ["exact", "section-only", "unresolved"] },
        "href": { "type": "string", "minLength": 1 }
      }
    },
    "reference": {
      "type": "object",
      "required": ["display", "sectionCitation", "resolution"],
      "additionalProperties": false,
      "properties": {
        "display": { "type": "string", "minLength": 1 },
        "sectionCitation": { "type": "string", "minLength": 1 },
        "resolution": { "$ref": "#/$defs/resolution" }
      }
    },
    "rule": {
      "type": "object",
      "required": ["id", "authorityCitation", "sectionCitation", "description", "affectedText", "comments", "pages", "revision", "authorityResolution", "affectedReferences"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^fee-rule-[0-9a-f]{16}$" },
        "authorityCitation": { "type": "string", "minLength": 1 },
        "sectionCitation": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "affectedText": { "type": "string", "minLength": 1 },
        "comments": { "type": "string" },
        "pages": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "integer", "minimum": 1 } },
        "revision": { "type": ["string", "null"] },
        "authorityResolution": { "$ref": "#/$defs/resolution" },
        "affectedReferences": { "type": "array", "items": { "$ref": "#/$defs/reference" } }
      }
    }
  }
}
