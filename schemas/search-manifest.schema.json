{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://uconn-law-library.github.io/CGS/schemas/search-manifest.schema.json",
  "title": "CGS search manifest",
  "type": "object",
  "required": ["schemaVersion", "generatedAt", "shards"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "shards": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["titleId", "path", "documentCount"],
        "additionalProperties": false,
        "properties": {
          "titleId": { "type": "string", "pattern": "^title-[0-9a-z-]+$" },
          "path": { "type": "string", "pattern": "^title-[0-9a-z-]+\\.json$" },
          "documentCount": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
