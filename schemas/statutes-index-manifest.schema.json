{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://uconn-law-library.github.io/CGS/schemas/statutes-index-manifest.schema.json",
  "title": "CGS subject index manifest",
  "type": "object",
  "required": ["schemaVersion", "generatedAt", "source", "counts", "shards"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "source": {
      "type": "object",
      "required": ["name", "publisher", "url", "revision", "pageCount", "files"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "publisher": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "format": "uri" },
        "revision": { "type": "string", "minLength": 1 },
        "pageCount": { "type": "integer", "minimum": 1 },
        "files": { "type": "array", "minItems": 3, "items": { "$ref": "#/$defs/file" } }
      }
    },
    "counts": {
      "type": "object",
      "required": ["headings", "items", "references", "resolved"],
      "additionalProperties": false,
      "properties": {
        "headings": { "type": "integer", "minimum": 0 },
        "items": { "type": "integer", "minimum": 0 },
        "references": { "type": "integer", "minimum": 0 },
        "resolved": { "type": "integer", "minimum": 0 }
      }
    },
    "shards": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["key", "path", "headingCount", "itemCount"],
        "additionalProperties": false,
        "properties": {
          "key": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "pattern": "^[0-9a-z-]+\\.json$" },
          "headingCount": { "type": "integer", "minimum": 0 },
          "itemCount": { "type": "integer", "minimum": 0 }
        }
      }
    }
  },
  "$defs": {
    "file": {
      "type": "object",
      "required": ["name", "url", "bytes", "sha256"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "format": "uri" },
        "bytes": { "type": "integer", "minimum": 1 },
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    }
  }
}
