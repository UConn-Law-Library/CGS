{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://uconn-law-library.github.io/CGS/schemas/supplement-index.schema.json",
  "title": "CGS supplement edition index",
  "type": "object",
  "required": ["schemaVersion", "generatedAt", "editions"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "editions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["editionYear", "generatedAt", "path", "counts"],
        "additionalProperties": false,
        "properties": {
          "editionYear": { "type": "integer", "minimum": 2000 },
          "generatedAt": { "type": "string", "format": "date-time" },
          "path": { "type": "string", "pattern": "^[0-9]{4}/manifest\\.json$" },
          "counts": {
            "type": "object",
            "required": ["titles", "chapters", "sections", "replacements", "additions"],
            "additionalProperties": false,
            "properties": {
              "titles": { "type": "integer", "minimum": 0 },
              "chapters": { "type": "integer", "minimum": 0 },
              "sections": { "type": "integer", "minimum": 0 },
              "replacements": { "type": "integer", "minimum": 0 },
              "additions": { "type": "integer", "minimum": 0 }
            }
          }
        }
      }
    }
  }
}
